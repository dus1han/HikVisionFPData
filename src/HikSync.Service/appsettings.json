{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/hiksync-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },

  "LocalDatabase": {
    "ConnectionString": "Host=localhost;Port=5432;Database=hiksync;Username=hiksync;Password=CHANGE_ME",
    "MigrateOnStartup": true
  },

  "Sdk": {
    "NativeLibraryPath": "native",
    "UseFakeDevice": false,
    "LoginTimeoutSeconds": 10
  },

  "Attendance": {
    "IntervalSeconds": 60,
    "BackfillStartUtc": null,
    "CountedVerifyModes": [],
    "DeviceUtcOffsetMinutes": null,
    "MaxConcurrentDevices": 4
  },

  "Sync": {
    "Enabled": true,
    "IntervalSeconds": 300,
    "DeleteRemovedUsers": false
  },

  "Push": {
    "Enabled": false,
    "IntervalSeconds": 60,
    "BatchSize": 200,
    "MaxAttempts": 8,
    "Endpoint": "http://REMOTE_API_IP:PORT/api/attendance",
    "AuthType": "None",
    "AuthValue": null,
    "ApiKeyHeader": "X-API-Key",
    "TimeoutSeconds": 30
  },

  "Log": {
    "RetentionEnabled": true,
    "RetentionDays": 30,
    "CleanupHourLocal": 2
  }
}
